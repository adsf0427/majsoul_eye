# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Test / coverage output
.coverage
coverage.xml
htmlcov/

# Local environments
.venv/
venv/
env/

# Local editor / OS files
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Secrets / local config
.env
.env.*
!.env.example

# Captures, datasets, and generated labels
captures/
datasets/
*.jsonl
*.jsonl.log
# Deal-frame purge manifest — regenerable via purge_deal_frames.py --write-manifest;
# describes a local (gitignored) datasets/ snapshot, so it's a transfer artifact, not source.
deal_manifest*.json

# Browser/runtime data
.spike_browser_data/
liqi_proto/

# Training, export, and analysis outputs
fails/
runs/
outputs/
wandb/
mlruns/
*.onnx
*.engine
*.tflite

# Large model weights — kept locally, too big for GitHub's 50MB limit.
# Only the production classifier majsoul_eye/recognize/tile_classifier.pt stays tracked;
# all backup variants (tile_classifier_*.pt) and every detector weight are local-only.
majsoul_eye/recognize/tile_detector*.pt
majsoul_eye/recognize/tile_classifier_*.pt
/yolo*.pt

# weights/ — pretrained base seeds (weights/pretrained/) + optional detector
# variants (weights/detector/, e.g. AABB vs OBB). Blobs are local-only; the folder
# structure + README.md + .gitkeep stay tracked so the convention is versioned.
weights/**/*.pt
weights/**/*.onnx
weights/**/*.engine
weights/**/*.tflite
weights/**/*.pth

out/
scratchpad/

# Reference repo clones (own .git; never track)
_external/

# Python packaging build artifacts (from `pip install -e .`)
*.egg-info/
build/
dist/
samples/